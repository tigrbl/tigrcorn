    },
    {
      "order": 2,
      "target": "add_conditional_validators",
      "rfcs": [
        "RFC 7232"
      ],
      "features": [
        "ETag generation",
        "If-None-Match evaluation",
        "304 decision engine"
      ],
      "reason": "This is the highest-value next HTTP semantic family for an origin-style ASGI server."
    },
    {
      "order": 3,
      "target": "add_digest_fields",
      "rfcs": [
        "RFC 9530"
      ],
      "features": [
        "Content-Digest",
        "Repr-Digest"
      ],
      "reason": "Digest fields become a natural follow-on once representation metadata exists."
    },
    {
      "order": 4,
      "target": "cache_semantics_if_product_expands",
      "rfcs": [
        "RFC 9111"
      ],
      "reason": "Caching is a larger boundary decision and should remain optional unless tigrcorn becomes a cache/static-asset or intermediary product."
    },
    {
      "order": 5,
      "target": "message_signatures_if_gateway_role_emerges",
      "rfcs": [
        "RFC 9421"
      ],
      "reason": "HTTP Message Signatures are best treated as gateway/edge work rather than baseline transport-server scope."
    },
    {
      "order": 6,
