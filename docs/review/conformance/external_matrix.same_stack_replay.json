{
  "name": "tigrcorn-same-stack-replay-matrix",
  "metadata": {
    "description": "Replayable same-stack fixture matrix for HTTP/3, QUIC-TLS feature axes, and RFC 9220 coverage. These scenarios are useful regression evidence but are not independent certification artifacts.",
    "evidence_tier": "same_stack_replay",
    "peer_families": [
      "tigrcorn-public-client"
    ],
    "source_matrix": "external_matrix.current_release.json",
    "canonical_release_root": "docs/review/conformance/releases/0.3.6/release-0.3.6/tigrcorn-same-stack-replay-matrix"
  },
  "scenarios": [
    {
      "id": "http3-server-public-client-post",
      "protocol": "http3",
      "role": "server",
      "feature": "post-echo",
      "peer": "tigrcorn-public-client",
      "metadata": {
        "rfc": [
          "RFC 8446",
          "RFC 9000",
          "RFC 9001",
          "RFC 9114"
        ],
        "peer_implementation": "tigrcorn-public-client",
        "peer_independence": "same-stack"
      },
      "sut": {
        "name": "tigrcorn-http3",
        "adapter": "subprocess",
        "role": "server",
        "command": [
          "python",
          "-m",
          "tigrcorn",
          "examples.echo_http.app:app",
          "--transport",
          "udp",
          "--host",
          "{bind_host}",
          "--port",
          "{bind_port}",
          "--protocol",
          "http3",
          "--http",
          "3",
          "--ssl-certfile",
          "tests/fixtures_certs/interop-localhost-cert.pem",
          "--ssl-keyfile",
          "tests/fixtures_certs/interop-localhost-key.pem",
          "--no-access-log",
          "--lifespan",
          "off",
          "--disable-websocket"
        ],
        "ready_pattern": "listening on",
        "version_command": [
          "python",
          "-m",
          "tigrcorn",
          "--help"
        ],
        "provenance_kind": "package_owned",
        "implementation_source": "tigrcorn",
        "implementation_identity": "tigrcorn-http3",
        "implementation_version": "0.3.6"
      },
      "peer_process": {
        "name": "tigrcorn-public-http3-client",
        "adapter": "subprocess",
        "role": "client",
        "command": [
          "python",
          "-m",
          "tests.fixtures_pkg.external_http3_client",
          "--servername",
          "localhost",
          "--cacert",
          "tests/fixtures_certs/interop-localhost-cert.pem"
        ],
        "env": {
          "INTEROP_REQUEST_BODY": "hello-http3"
        },
        "version_command": [
          "python",
          "-m",
          "tests.fixtures_pkg.external_http3_client",
          "--version"
        ],
        "provenance_kind": "same_stack_fixture",
        "implementation_source": "tigrcorn.tests.fixtures_pkg",
        "implementation_identity": "tigrcorn-public-client",
        "implementation_version": "0.3.6"
      },
      "assertions": [
        {
          "path": "peer.exit_code",
          "equals": 0
        },
        {
          "path": "transcript.peer.response.status",
          "equals": 200
        },
        {
          "path": "transcript.peer.response.body",
          "equals": "echo:hello-http3"
        },
        {
          "path": "negotiation.peer.protocol",
          "equals": "h3"
        },
        {
          "path": "artifacts.packet_trace.exists",
          "equals": true
        },
        {
          "path": "artifacts.qlog.exists",
          "equals": true
        }
      ],
      "evidence_tier": "same_stack_replay"
    },
