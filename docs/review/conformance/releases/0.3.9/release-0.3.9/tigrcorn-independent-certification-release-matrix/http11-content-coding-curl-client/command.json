{
  "sut": {
    "command": [
      "python",
      "-m",
      "tigrcorn",
      "tests.fixtures_pkg.interop_content_coding_app:app",
      "--host",
      "{bind_host}",
      "--port",
      "{bind_port}",
      "--protocol",
      "http1",
      "--disable-websocket",
      "--no-access-log",
      "--lifespan",
      "off"
    ],
    "version_command": [
      "python",
      "-m",
      "tigrcorn",
      "--help"
    ],
    "name": "tigrcorn-http1-content-coding",
    "adapter": "subprocess"
  },
  "peer": {
    "command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_curl_client",
      "--http1",
      "--content-coding"
    ],
    "version_command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_curl_client",
      "--version"
    ],
    "name": "curl-http1-content-coding-client",
    "adapter": "subprocess"
  }
}
