{
  "sut": {
    "command": [
      "python",
      "-m",
      "tigrcorn",
      "examples.echo_http.app:app",
      "--transport",
      "udp",
      "--host",
      "{bind_host}",
      "--port",
      "{bind_port}",
      "--http",
      "3",
      "--protocol",
      "http3",
      "--disable-websocket",
      "--ssl-certfile",
      "tests/fixtures_certs/interop-localhost-cert.pem",
      "--ssl-keyfile",
      "tests/fixtures_certs/interop-localhost-key.pem",
      "--no-access-log",
      "--lifespan",
      "off"
    ],
    "version_command": [
      "python",
      "-m",
      "tigrcorn",
      "--help"
    ],
    "name": "tigrcorn-http3",
    "adapter": "subprocess"
  },
  "peer": {
    "command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_openssl_quic_client",
      "--cafile",
      "tests/fixtures_certs/interop-localhost-cert.pem",
      "--servername",
      "localhost",
      "--alpn",
      "h3"
    ],
    "version_command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_openssl_quic_client",
      "--version"
    ],
    "name": "openssl-quic-client",
    "adapter": "subprocess"
  }
}
