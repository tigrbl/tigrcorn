{
  "sut": {
    "command": [
      "python",
      "-m",
      "tigrcorn",
      "examples.websocket_echo.app:app",
      "--host",
      "{bind_host}",
      "--port",
      "{bind_port}",
      "--http",
      "2",
      "--protocol",
      "http2",
      "--websocket-compression",
      "permessage-deflate",
      "--no-access-log",
      "--lifespan",
      "off"
    ],
    "version_command": [
      "python",
      "-m",
      "tigrcorn",
      "--help"
    ],
    "name": "tigrcorn-http2-websocket-permessage-deflate",
    "adapter": "subprocess"
  },
  "peer": {
    "command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_h2_websocket_client"
    ],
    "version_command": [
      "python",
      "-m",
      "tests.fixtures_pkg.external_h2_websocket_client",
      "--version"
    ],
    "name": "python-h2-websocket-client",
    "adapter": "subprocess"
  }
}
