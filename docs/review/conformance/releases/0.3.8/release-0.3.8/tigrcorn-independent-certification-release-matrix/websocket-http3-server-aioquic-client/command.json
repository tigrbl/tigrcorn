{
  "sut": {
    "command": [
      "python",
      "-m",
      "tigrcorn",
      "tests.fixtures_pkg.interop_h3_websocket_app:app",
      "--transport",
      "udp",
      "--host",
      "{bind_host}",
      "--port",
      "{bind_port}",
      "--protocol",
      "http3",
      "--http",
      "3",
      "--ssl-certfile",
      "tests/fixtures_certs/interop-localhost-cert.pem",
      "--ssl-keyfile",
      "tests/fixtures_certs/interop-localhost-key.pem",
      "--no-access-log",
      "--lifespan",
      "off"
    ],
    "version_command": [
      "python",
      "-m",
      "tigrcorn",
      "--help"
    ],
    "name": "tigrcorn-http3-websocket",
    "adapter": "subprocess"
  },
  "peer": {
    "command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tests.fixtures_third_party.aioquic_http3_websocket_client",
      "--servername",
      "localhost",
      "--cacert",
      "tests/fixtures_certs/interop-localhost-cert.pem"
    ],
    "version_command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tests.fixtures_third_party.aioquic_http3_websocket_client",
      "--version"
    ],
    "name": "aioquic-http3-websocket-client",
    "adapter": "subprocess"
  }
}
