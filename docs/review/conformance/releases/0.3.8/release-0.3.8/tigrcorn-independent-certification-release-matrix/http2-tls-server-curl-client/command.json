{
  "sut": {
    "command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tigrcorn",
      "examples.echo_http.app:app",
      "--host",
      "{bind_host}",
      "--port",
      "{bind_port}",
      "--http",
      "2",
      "--protocol",
      "http2",
      "--ssl-certfile",
      "tests/fixtures_certs/interop-localhost-cert.pem",
      "--ssl-keyfile",
      "tests/fixtures_certs/interop-localhost-key.pem",
      "--disable-websocket",
      "--no-access-log",
      "--lifespan",
      "off"
    ],
    "version_command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tigrcorn",
      "--help"
    ],
    "name": "tigrcorn-http2-tls",
    "adapter": "subprocess"
  },
  "peer": {
    "command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tests.fixtures_pkg.external_curl_client",
      "--http2",
      "--https",
      "--servername",
      "localhost",
      "--cacert",
      "tests/fixtures_certs/interop-localhost-cert.pem"
    ],
    "version_command": [
      "/opt/pyvenv/bin/python",
      "-m",
      "tests.fixtures_pkg.external_curl_client",
      "--version"
    ],
    "name": "curl-http2-tls-client",
    "adapter": "subprocess"
  }
}
